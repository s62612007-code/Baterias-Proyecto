{
  "name": "baterias-barracuda-taller-honda",
  "version": "1.0.0",
  "description": "Baterías Barracuda Taller Honda — catálogo y cotización en bateriascali.es",
  "author": "Ing. Santiago Martínez Vásquez",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "node --watch server/index.js",
    "start": "node server/index.js",
    "build": "node scripts/build-static.js",
    "deploy": "bash scripts/deploy-bateriascali-es.sh",
    "deploy:ftp": "python3 scripts/deploy-ftp-honda.py",
    "deploy:clean": "python3 scripts/cleanup-ftp-honda.py",
    "deploy:hondabateriacali": "bash scripts/deploy-hondabateriacali.sh",
    "deploy:bateriascali.es": "bash scripts/deploy-bateriascali-es.sh",
    "deploy:both": "bash scripts/deploy-both-sites.sh",
    "verify:deploy": "bash scripts/verify-deploy.sh",
    "verify:security": "bash scripts/verify-security.sh",
    "check:ns97": "bash scripts/check-ns97.sh",
